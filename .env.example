# ===========================================
# RuangRasa Teman - Environment Variables
# ===========================================
# Copy file ini ke `.env.local` lalu isi nilainya
#   cp .env.example .env.local
#
# JANGAN commit .env.local (sudah di-gitignore)

# --- Groq AI (untuk chatbot di /api/chat) ---
# Dapatkan di: https://console.groq.com/keys
GROQ_API_KEY=

# --- Google Sheets webhook (untuk /api/waitlist) ---
# URL Apps Script deployment (Deploy → Web App → /exec URL)
SHEETS_WEBHOOK_URL=

# Secret string untuk auth ke Apps Script
# Harus sama persis dengan `const SECRET = '...'` di Apps Script
WEBHOOK_SECRET=
